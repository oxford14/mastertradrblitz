{
  "manifest_version": 3,
  "name": "Master Trader Blitz",
  "version": "1.0.0",
  "key": "",
  "description": "RSI + Stochastic + Bollinger signal engine for Exnova 5-second binary options",
  "permissions": ["storage", "tabs", "nativeMessaging"],
  "host_permissions": ["https://trade.exnova.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://trade.exnova.com/*"],
      "js": ["src/content/ws-interceptor.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://trade.exnova.com/*"],
      "js": ["src/content/page-bridge.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://trade.exnova.com/*"],
      "js": ["src/content/main.tsx"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "public/icon-16.png",
    "48": "public/icon-48.png",
    "128": "public/icon-128.png"
  },
  "action": {
    "default_title": "Master Trader Blitz",
    "default_icon": {
      "16": "public/icon-16.png",
      "48": "public/icon-48.png",
      "128": "public/icon-128.png"
    }
  }
}
